# Copy this file to .env for local, single-user development. The MVP has no
# end-user authentication; keep API and web ports on loopback. Never commit a
# real API key, production database password, or student data.

APP_NAME=CodeReason API
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

# Direct host execution defaults to the zero-setup SQLite database below.
DATABASE_URL=sqlite:///./codereason.db

# Docker Compose constructs its service URL from the PostgreSQL values below.
# These are local-demo credentials; this unauthenticated MVP is not for remote use.
POSTGRES_DB=codereason
POSTGRES_USER=codereason
POSTGRES_PASSWORD=codereason-local-only

# Enables the destructive POST /api/demo/reset route. Disable outside a local
# demo. FIXTURE requests create DEMO_FIXTURE records; LIVE requests queue work.
DEMO_MODE=true

# Browser-visible API URL. Never put a secret in a NEXT_PUBLIC_* variable.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
# Server-side Next.js URL used inside Compose; browsers never use this hostname.
API_INTERNAL_BASE_URL=http://api:8000/api

# Guards hidden worker-owned mutation adapters in the API. This is not user
# authentication. The worker normally persists results through its DB session.
INTERNAL_WORKER_TOKEN=codereason-local-internal-change-me

# Leave empty to show "AI unavailable". Demo fixtures remain visibly labelled
# as fixtures and are never presented as live provider output.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
